# =============================================================================
# Wallet Chat — environment configuration
# Copy to .env and fill in real values. AUTH_SECRET and JWT_SECRET MUST be
# identical between the web app and the server (the auth bridge depends on it).
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# --- Required (web + server) -------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/connext
# Signs Auth.js sessions and the short-lived API bridge payload
AUTH_SECRET=generate_a_long_random_string
# Signs the API session JWT cookie
JWT_SECRET=generate_another_long_random_string

# --- App URLs ----------------------------------------------------------------
# Canonical URL of the Next.js app (required in production)
AUTH_URL=http://localhost:3000
# Public URL of the Express API, read by the web client
NEXT_PUBLIC_SERVER_URL=http://localhost:4001
# Comma-separated CORS allowlist (enforced in production)
ALLOWED_ORIGINS=http://localhost:3000
# Express API port
PORT=4001
# JWT lifetime (default 7d)
JWT_EXPIRES_DAYS=7d

# --- Authentication providers (at least one required to sign in) -------------
# Google OAuth — https://console.cloud.google.com/ → APIs & Services → Credentials
# Redirect URI: <AUTH_URL>/api/auth/callback/google
# Provider is enabled only when BOTH values are set.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Passwordless email magic link (Nodemailer over SMTP)
# Format: smtp://<user>:<password>@<host>:<port>
# Gmail: create an App Password and URL-encode special characters.
# Provider is enabled only when EMAIL_SERVER is set. Requires DATABASE_URL.
EMAIL_SERVER=smtp://user:app_password@smtp.example.com:587
EMAIL_FROM="Wallet Chat <noreply@example.com>"

# --- Media storage: Cloudflare R2 (optional) ---------------------------------
# Media features are disabled unless all four core values are set.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
# Pre-signed URL lifetime in seconds (default 300)
R2_SIGNED_URL_TTL_SECONDS=300
# Max media upload size in bytes (default 26214400 = 25 MB)
MAX_MEDIA_FILE_BYTES=26214400

# --- Push notifications: Firebase Cloud Messaging (optional) -----------------
# Push is disabled unless all three are set. Use a service-account key.
# Escape newlines in the private key as \n (kept on one line).
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
