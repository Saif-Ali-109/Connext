# =============================================================================
# Connext — Server (Express) environment configuration
# Copy this file to .env and fill in the real values.
#
# AUTH_SECRET and JWT_SECRET MUST match the values in apps/web/.env.local
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# --- Database ----------------------------------------------------------------
# PostgreSQL connection string (used by Drizzle ORM)
DATABASE_URL=postgresql://user:password@host:5432/connext

# --- Auth secrets (must match apps/web) --------------------------------------
# Used to verify the HMAC-signed bridge payload sent from the Next.js app
AUTH_SECRET=generate_a_long_random_string
# Signs and verifies the httpOnly JWT session cookie issued to clients
JWT_SECRET=generate_another_long_random_string
# JWT session lifetime (e.g. 7d, 24h, 3600s)
JWT_EXPIRES_DAYS=7d

# --- Server ------------------------------------------------------------------
# Port the Express server listens on
PORT=4001
# Comma-separated list of allowed CORS origins (enforced in production)
ALLOWED_ORIGINS=http://localhost:3000

# --- Media storage: Cloudflare R2 (optional) ---------------------------------
# All four core values must be set to enable media/file upload features.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
# Pre-signed URL lifetime in seconds (default: 300 = 5 minutes)
R2_SIGNED_URL_TTL_SECONDS=300
# Maximum upload size in bytes (default: 26214400 = 25 MB)
MAX_MEDIA_FILE_BYTES=26214400

# --- Push notifications: Firebase Cloud Messaging (optional) -----------------
# All three values must be set to enable push notifications.
# Use a Firebase service-account key; escape newlines in the private key as \n
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
