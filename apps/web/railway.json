{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build --workspace=@connext/db && npm run build --workspace=connext-web"
  },
  "deploy": {
    "startCommand": "npm run start --workspace=connext-web",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
